{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list" } },
      "targets": [
        {
          "expr": "instance:node_cpu_usage:percent",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "title": "CPU Usage % (Recording Rule)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "Available - {{ instance }}",
          "refId": "A"
        }
      ],
      "title": "Memory Available (Instant Vector)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count[5m])",
          "legendFormat": "rate - {{ uri }}",
          "refId": "A"
        },
        {
          "expr": "irate(http_server_requests_seconds_count[5m])",
          "legendFormat": "irate - {{ uri }}",
          "refId": "B"
        }
      ],
      "title": "HTTP Request Rate vs Irate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{ job }} - {{ instance }}",
          "refId": "A"
        }
      ],
      "title": "Target Health (Instant Vector - up)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "targets": [
        {
          "expr": "job:http_requests:rate5m",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ],
      "title": "HTTP Request Rate by Job (Recording Rule)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["yassen_hamdy", "metrics"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
